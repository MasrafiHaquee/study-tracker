rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requester logged in? ──
    function loggedIn() {
      return request.auth != null;
    }

    // ── Helper: is this a bot document? (ID starts with "bot_") ──
    function isBotDoc(docId) {
      return docId.matches('bot_.*');
    }

    // ── Helper: is the requester the owner of this doc? ──
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────
    //  users collection
    // ─────────────────────────────────────────────
    match /users/{userId} {
      // Anyone logged in can read (needed for leaderboard names)
      allow read: if loggedIn();

      // User can write their own doc
      allow write: if loggedIn() && isOwner(userId);

      // ANY logged-in user can create/update/delete bot docs
      // (bot IDs always start with "bot_")
      allow write: if loggedIn() && isBotDoc(userId);
    }

    // ─────────────────────────────────────────────
    //  leaderboardData collection
    // ─────────────────────────────────────────────
    match /leaderboardData/{userId} {
      // Anyone logged in can read leaderboard
      allow read: if loggedIn();

      // User can write their own entry
      allow write: if loggedIn() && isOwner(userId);

      // Any logged-in user can write bot leaderboard entries
      allow write: if loggedIn() && isBotDoc(userId);
    }

    // ─────────────────────────────────────────────
    //  studySessions collection
    // ─────────────────────────────────────────────
    match /studySessions/{sessionId} {
      allow read: if loggedIn();
      allow create: if loggedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if loggedIn() &&
                                resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    //  tasks collection
    // ─────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if loggedIn() && resource.data.userId == request.auth.uid;
      allow create: if loggedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if loggedIn() &&
                                resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    //  quizzes / doubts
    // ─────────────────────────────────────────────
    match /quizzes/{docId} {
      allow read: if loggedIn();
      allow write: if loggedIn();
    }

    match /doubts/{docId} {
      allow read: if loggedIn();
      allow create: if loggedIn();
      allow update, delete: if loggedIn() &&
                                resource.data.userId == request.auth.uid;
    }
  }
}
